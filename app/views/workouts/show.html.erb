<% content_for :title, @workout.title %>

<section class="card panel-card exercise-detail">
  <div class="section-heading">
    <div>
      <%= link_to workouts_path, class: "breadcrumb" do %>
        <span class="breadcrumb-label">Workouts</span>
      <% end %>
      <h1><%= @workout.title %></h1>
      <p class="supporting-text"><%= @workout.workout_on.to_fs(:long) %> · <%= @workout.status.humanize %></p>
    </div>

    <div class="workout-actions">
      <div class="workout-actions-primary">
        <% if @workout.status == "draft" %>
          <%= button_to "Start workout", workout_path(@workout), method: :patch, params: { workout: { status: "in_progress" } }, class: "button" %>
        <% elsif @workout.status == "in_progress" %>
          <%= button_to "Complete workout", workout_path(@workout), method: :patch, params: { workout: { status: "completed" } }, class: "button" %>
        <% else %>
          <%= button_to "Reopen workout", workout_path(@workout), method: :patch, params: { workout: { status: "draft" } }, class: "button" %>
        <% end %>
      </div>

      <div class="workout-actions-secondary">
        <%= link_to "Edit", edit_workout_path(@workout), class: "button button-ghost" %>
        <% if @workout.status.in?(["draft", "in_progress"]) %>
          <%= button_to "Cancel", workout_path(@workout), method: :patch, params: { workout: { status: "cancelled" } }, class: "button button-ghost", form: { data: { turbo_confirm: "Cancel this workout? You can reopen it later from the workout page." } } %>
        <% end %>
      </div>
    </div>
  </div>

  <dl class="detail-grid">
    <div>
      <dt>Status</dt>
      <dd><%= @workout.status.humanize %></dd>
    </div>

    <%= render "workouts/difficulty_totals", workout: @workout %>

    <div>
      <dt>Workout date</dt>
      <dd><%= @workout.workout_on.to_fs(:long) %></dd>
    </div>

    <div>
      <dt>Active workout</dt>
      <dd><%= @workout.status == "in_progress" ? "Yes" : "No" %></dd>
    </div>
  </dl>

  <div>
    <p class="panel-label">Notes</p>
    <% if @workout.notes.present? %>
      <div class="supporting-text workout-summary-notes workout-note-markdown"><%= render_markdown(@workout.notes) %></div>
    <% else %>
      <p class="supporting-text">No notes yet.</p>
    <% end %>
  </div>
</section>

<section class="card panel-card">
  <div class="section-heading">
    <div>
      <p class="panel-label">Workout sets</p>
      <h2 id="planned_sets_count"><%= render "workouts/planned_sets_count", workout: @workout %></h2>
    </div>
  </div>

  <%= turbo_frame_tag "planned_set_planner" do %>
    <%= render "workouts/planned_set_planner", workout: @workout, exercises: @exercises, planned_entry: @planned_entry, execution_entry: @execution_entry %>
  <% end %>

  <%= turbo_frame_tag "planned_sets_list" do %>
    <%= render "workouts/planned_sets_list", workout: @workout %>
  <% end %>
</section>
