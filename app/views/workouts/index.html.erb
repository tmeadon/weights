<% content_for :title, "Workouts" %>

<% if @active_workout.present? %>
  <section class="card panel-card active-workout-card">
    <div>
      <p class="panel-label">Active workout</p>
      <h2>
        <%= link_to workout_path(@active_workout) do %>
          <%= @active_workout.title %>
          <span class="workout-row-date"><%= workout_relative_date(@active_workout.workout_on) %></span>
        <% end %>
      </h2>
      <p class="supporting-text"><%= @active_workout.workout_on.to_fs(:long) %> · In progress</p>
    </div>
  </section>
<% end %>

<section class="card panel-card">
  <div class="section-heading">
    <div>
      <h1>Workouts</h1>
      <p class="supporting-text"><%= pluralize(@workouts.count, "workout") %> tracked.</p>
    </div>

    <div>
      <%= link_to "New workout", new_workout_path, class: "button" %>
    </div>
  </div>

  <% if @workouts.any? %>
    <div class="exercise-list workout-list">
      <% @workouts.each do |workout| %>
        <article class="workout-row">
          <div class="exercise-heading">
            <h3>
              <%= link_to workout_path(workout) do %>
                <%= workout.title %>
                <span class="workout-row-date"><%= workout_relative_date(workout.workout_on) %></span>
              <% end %>
            </h3>
            <%= link_to "Edit", edit_workout_path(workout), class: "exercise-edit-link" %>
          </div>

          <p class="exercise-meta">
            <%= workout.workout_on.to_fs(:long) %> / <%= workout.status.humanize %> / Difficulty <%= number_with_precision(workout.total_difficulty, precision: 1) %>
          </p>

          <% if workout.notes.present? %>
            <p class="supporting-text workout-note-preview"><%= workout.notes %></p>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="supporting-text">No workouts yet. Start with a title, date, and a few notes for the session.</p>
  <% end %>
</section>
