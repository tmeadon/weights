<% content_for :title, "New workout" %>

<section class="auth-layout auth-layout-compact">
  <div class="card auth-card">
    <p class="eyebrow">Workout notebook</p>
    <h1>Create a workout</h1>
    <p class="supporting-text">Start with the session title and day, then fill a compact set builder without hopping through a separate form for every set.</p>

    <%= render "form", workout: @workout, exercises: @exercises, planned_entries: @planned_entries %>
  </div>
</section>
