<% exercise_groups = local_assigns[:exercise_groups] || @exercise_groups || workout.planned_exercise_groups %>

<% if exercise_groups.any? %>
  <div class="exercise-list workout-list">
    <% exercise_groups.each_with_index do |(exercise, grouped_sets), index| %>
      <article class="workout-row planned-group-row" data-controller="fill-down">
        <div class="exercise-heading">
          <h3><%= exercise.name %></h3>
          <div class="exercise-actions">
            <% can_reorder = workout.status.in?(%w[draft in_progress]) %>
            <% if can_reorder %>
              <%= button_to "↑", move_exercise_workout_workout_sets_path(workout, exercise_id: exercise.id, direction: "up"), method: :patch, class: "link-button exercise-order-link", form_class: "link-button-form", aria: { label: "Move #{exercise.name} up" }, disabled: index.zero? %>
              <%= button_to "↓", move_exercise_workout_workout_sets_path(workout, exercise_id: exercise.id, direction: "down"), method: :patch, class: "link-button exercise-order-link", form_class: "link-button-form", aria: { label: "Move #{exercise.name} down" }, disabled: index == exercise_groups.size - 1 %>
            <% end %>
            <% if workout.status == "in_progress" %>
              <button type="button" class="link-button exercise-fill-link" data-action="click->fill-down#fillDown">Fill down</button>
            <% end %>
            <%= button_to "Remove exercise", remove_exercise_workout_workout_sets_path(workout, exercise_id: exercise.id), method: :delete, class: "link-button exercise-remove-link", form_class: "link-button-form" %>
          </div>
        </div>

        <% notes = grouped_sets.map(&:coach_notes).compact.uniq %>
        <% if notes.any? %>
          <div class="supporting-text workout-note-preview">
            <%= safe_join(notes.map { |note| content_tag(:div, render_markdown(note), class: "workout-note-markdown") }) %>
          </div>
        <% end %>

        <div class="planned-set-table">
          <div class="planned-set-row planned-set-header">
            <span>Set</span>
            <span>Planned</span>
            <span>Actual</span>
            <span></span>
          </div>

          <% grouped_sets.each do |workout_set| %>
            <div class="planned-set-row" data-fill-down-target="row" data-target-reps="<%= workout_set.target_reps %>" data-target-weight="<%= workout_set.target_weight %>">
              <span class="planned-set-index"><%= workout_set.position %></span>
              <div>
                <% if workout_set.target_reps.present? || workout_set.target_weight.present? %>
                  <span class="planned-set-compact"><%= workout_set.target_reps || "-" %> x <%= workout_set.target_weight.present? ? number_with_precision(workout_set.target_weight, precision: 1) : "-" %>kg</span>
                  <span class="planned-set-full"><%= workout_set.target_reps || "-" %> reps<% if workout_set.target_weight.present? %> @ <%= number_with_precision(workout_set.target_weight, precision: 1) %> kg<% end %></span>
                <% elsif workout_set.actual_logged? %>
                  <span class="planned-set-muted">Added live</span>
                <% else %>
                  <span class="planned-set-muted">Targets pending</span>
                <% end %>
              </div>
              <div>
                <% if workout.status == "in_progress" %>
                  <%= form_with url: workout_workout_set_path(workout, workout_set), method: :patch, scope: :execution, class: "actual-set-form", local: false, data: { controller: "autosave", autosave_delay_value: 250 } do |form| %>
                    <% weight_placeholder = "" %>
                    <% reps_placeholder = "" %>
                    <div class="actual-field">
                      <%= form.number_field :actual_weight, value: workout_set.actual_weight, min: 0, step: 0.5, placeholder: weight_placeholder, class: "planner-input actual-set-input", data: { action: "focus->autosave#prefillFromAbove input->autosave#queue blur->autosave#submit" } %>
                      <span class="actual-field-unit">kg</span>
                    </div>
                    <div class="actual-field">
                      <%= form.number_field :actual_reps, value: workout_set.actual_reps, min: 1, placeholder: reps_placeholder, class: "planner-input actual-set-input", data: { action: "focus->autosave#prefillFromAbove input->autosave#queue blur->autosave#submit" } %>
                      <span class="actual-field-unit">reps</span>
                    </div>
                    <button type="button" class="autosave-status" data-action="click->autosave#retry" data-autosave-target="status" hidden disabled aria-live="polite"></button>
                  <% end %>

                  <% if workout_set.errors.any? %>
                    <div class="actual-set-errors"><%= workout_set.errors.full_messages.to_sentence %></div>
                  <% end %>
                <% elsif workout_set.actual_logged? %>
                  <span><%= workout_set.actual_reps || "-" %> reps<% if workout_set.actual_weight.present? %> @ <%= number_with_precision(workout_set.actual_weight, precision: 1) %> kg<% end %></span>
                <% else %>
                  <span class="planned-set-muted">—</span>
                <% end %>
              </div>
              <% if workout.status.in?(%w[draft in_progress]) %>
                <%= button_to "x", workout_workout_set_path(workout, workout_set), method: :delete, class: "chip-remove", form_class: "chip-remove-form", aria: { label: "Remove set #{workout_set.position}" } %>
              <% end %>
            </div>
          <% end %>
        </div>

        <%= render "workouts/exercise_progress_hint", workout: workout, exercise: exercise, grouped_sets: grouped_sets %>

      </article>
    <% end %>
  </div>
<% else %>
  <p class="supporting-text">No sets yet. Add exercises to give the workout structure before logging starts.</p>
<% end %>
