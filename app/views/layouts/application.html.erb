<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Weights" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Weights">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body">
    <div class="app-shell">
      <header class="topbar">
        <div class="topbar-primary">
          <%= link_to "Weights", root_path, class: "brand" %>

          <% if authenticated? %>
            <nav class="topbar-nav" aria-label="Primary">
              <%= link_to "Workouts", workouts_path, class: ["topbar-pill", (current_page?(workouts_path) ? "topbar-pill-active" : nil)] %>
              <%= link_to "Exercises", exercises_path, class: ["topbar-pill", (current_page?(exercises_path) ? "topbar-pill-active" : nil)] %>
              <%= link_to "Progression", progressions_path, class: ["topbar-pill", (current_page?(progressions_path) ? "topbar-pill-active" : nil)] %>
              <span class="topbar-nav-spacer"></span>
              <%= link_to "Me", account_path, class: ["topbar-link", (current_page?(account_path) ? "topbar-link-active" : nil)] %>
            </nav>
          <% end %>
        </div>

        <div class="topbar-secondary">
          <% unless authenticated? %>
            <%= link_to "Sign in", new_session_path, class: "topbar-link" %>
            <%= link_to "Create account", new_registration_path, class: "topbar-pill topbar-pill-active" %>
          <% end %>
        </div>
      </header>

      <main class="page-shell">
        <% flash.each do |type, message| %>
          <div class="<%= flash_class(type) %>"><%= message %></div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
