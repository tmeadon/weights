<% content_for :title, "Account" %>

<section class="auth-layout auth-layout-compact">
  <div class="card auth-card">
    <p class="eyebrow">Account</p>
    <h1>Me</h1>
    <p class="supporting-text">Signed in as <%= current_user.email_address %>.</p>

    <dl class="detail-grid account-detail-grid">
      <div>
        <dt>Email</dt>
        <dd><%= current_user.email_address %></dd>
      </div>
      <div>
        <dt>API key</dt>
        <dd><code><%= current_user.api_key %></code></dd>
      </div>
    </dl>

    <p class="supporting-text">Use this key with <code>X-Api-Key</code> or <code>Authorization: Bearer &lt;key&gt;</code>.</p>

    <div class="button-row">
      <%= button_to "Sign out", session_path, method: :delete, class: "button button-ghost" %>
    </div>
  </div>
</section>
