<% content_for :title, "Progression" %>

<section class="card panel-card">
  <div class="section-heading">
    <div>
      <h1>Progression</h1>
      <p class="supporting-text">Track planned vs actual workload and drill into per-exercise trends.</p>
    </div>
  </div>

  <%= turbo_frame_tag "progression_panel" do %>
    <nav class="progression-tabs" aria-label="Progression sections">
      <%= link_to "Workouts", progressions_path(tab: "workouts", workout_type: @selected_workout_type, exercise_id: @selected_exercise_id, chart_mode: @chart_mode), class: ["topbar-pill", (@tab == "workouts" ? "topbar-pill-active" : nil)] %>
      <%= link_to "Exercises", progressions_path(tab: "exercises", workout_type: @selected_workout_type, exercise_id: @selected_exercise_id, chart_mode: @chart_mode), class: ["topbar-pill", (@tab == "exercises" ? "topbar-pill-active" : nil)] %>
    </nav>

    <%= form_with url: progressions_path, method: :get, class: ["progression-filter-grid", (@tab == "exercises" ? "form-grid-two" : "progression-filter-grid-single")], local: true, data: { turbo_frame: "progression_panel" } do %>
      <%= hidden_field_tag :tab, @tab %>
      <%= hidden_field_tag :chart_mode, @chart_mode %>
      <div class="field">
        <%= label_tag :workout_type, "Workout type" %>
        <%= select_tag :workout_type, options_for_select([["All types", ""]] + @workout_types.map { |type| [type.humanize, type] }, @selected_workout_type), onchange: "this.form.submit()" %>
      </div>

      <% if @tab == "exercises" %>
        <div class="field">
          <%= label_tag :exercise_id, "Exercise" %>
          <%= select_tag :exercise_id, options_for_select([["All exercises", ""]] + @exercise_stats.map { |entry| ["#{entry[:exercise].name} (#{entry[:sessions]})", entry[:exercise].id] }, @selected_exercise_id), onchange: "this.form.submit()" %>
        </div>
      <% end %>

      <div class="button-row progression-filter-actions">
        <%= link_to "Reset", progressions_path(tab: @tab), class: "button button-ghost" %>
      </div>
    <% end %>
</section>

<% if @tab == "workouts" %>
<%= turbo_frame_tag "progression_workouts" do %>
<section class="card panel-card">
  <div class="section-heading">
    <div>
      <p class="panel-label">Difficulty</p>
      <h2>Planned vs actual by workout</h2>
      <% if @progress_workouts.any? %>
        <% oldest = @progress_workouts.min_by { |workout| [workout.workout_on, workout.created_at] } %>
        <% newest = @progress_workouts.max_by { |workout| [workout.workout_on, workout.created_at] } %>
        <p class="supporting-text progression-timeframe">
          Totals from <%= oldest.workout_on.to_fs(:long) %> to <%= newest.workout_on.to_fs(:long) %>.
        </p>
      <% else %>
        <p class="supporting-text progression-timeframe">Totals update once completed workouts are available.</p>
      <% end %>
    </div>
  </div>

  <div class="detail-grid progression-summary-grid">
    <div>
      <dt>Sessions</dt>
      <dd><%= @difficulty_summary[:sessions] %></dd>
    </div>
    <div>
      <dt>Planned total</dt>
      <dd><%= number_with_precision(@difficulty_summary[:planned_total], precision: 1) %></dd>
    </div>
    <div>
      <dt>Actual total</dt>
      <dd><%= number_with_precision(@difficulty_summary[:actual_total], precision: 1) %></dd>
    </div>
    <div>
      <dt>Delta</dt>
      <dd class="progression-delta <%= @difficulty_summary[:delta_total] >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>">
        <%= number_with_precision(@difficulty_summary[:delta_total], precision: 1) %>
      </dd>
    </div>
  </div>

  <% planned_total = @difficulty_summary[:planned_total].to_d %>
  <% actual_total = @difficulty_summary[:actual_total].to_d %>
  <% attainment_percent = if planned_total.positive?
    (actual_total / planned_total * 100)
  elsif actual_total.positive?
    BigDecimal("100")
  else
    BigDecimal("100")
  end %>
  <% capped_fill = [[attainment_percent.to_f, 0.0].max, 100.0].min %>
  <% overflow = planned_total.positive? ? [attainment_percent.to_f - 100.0, 0.0].max : 0.0 %>
  <% overflow_capped = [overflow, 100.0].min %>
  <% attainment_note = if planned_total.zero? && actual_total.positive?
    "No planned load set; this is all unplanned work."
  elsif planned_total.zero?
    "No planned load yet."
  elsif attainment_percent >= 100
    "#{number_with_precision(attainment_percent - 100, precision: 1)}% above plan"
  else
    "#{number_with_precision(100 - attainment_percent, precision: 1)}% below plan"
  end %>

  <div class="progression-attainment" role="img" aria-label="Actual is <%= number_with_precision(attainment_percent, precision: 1) %> percent of planned load">
    <div class="progression-attainment-track">
      <span class="progression-attainment-fill <%= attainment_percent >= 100 ? "progression-attainment-fill-over" : "progression-attainment-fill-under" %>" style="width: <%= capped_fill %>%"></span>
      <% if overflow_capped.positive? %>
        <span class="progression-attainment-overflow" style="width: <%= overflow_capped %>%"></span>
      <% end %>
      <span class="progression-attainment-target" aria-hidden="true"></span>
    </div>
    <div class="progression-attainment-text">
      <span><strong>Attainment</strong> <%= number_with_precision(attainment_percent, precision: 1) %>% of plan</span>
      <span><%= attainment_note %></span>
    </div>
  </div>

  <% if @workout_chart_points.any? %>
    <nav class="progression-chart-modes" aria-label="Chart mode">
      <%= link_to "Absolute", progressions_path(tab: "workouts", workout_type: @selected_workout_type, exercise_id: @selected_exercise_id, chart_mode: "absolute"), class: ["topbar-pill", (@chart_mode == "absolute" ? "topbar-pill-active" : nil)], data: { turbo_frame: "progression_workouts" } %>
      <%= link_to "Delta", progressions_path(tab: "workouts", workout_type: @selected_workout_type, exercise_id: @selected_exercise_id, chart_mode: "delta"), class: ["topbar-pill", (@chart_mode == "delta" ? "topbar-pill-active" : nil)], data: { turbo_frame: "progression_workouts" } %>
    </nav>

    <% chart_width = 640 %>
    <% chart_height = 230 %>
    <% pad_left = 34 %>
    <% pad_right = 10 %>
    <% pad_top = 16 %>
    <% pad_bottom = 34 %>
    <% plot_width = chart_width - pad_left - pad_right %>
    <% plot_height = chart_height - pad_top - pad_bottom %>
    <% step_x = @workout_chart_points.size > 1 ? (plot_width.to_f / (@workout_chart_points.size - 1)) : 0 %>
    <% first_label = @workout_chart_points.first[:label] %>
    <% last_label = @workout_chart_points.last[:label] %>

    <% if @chart_mode == "delta" %>
      <% max_abs = @workout_chart_points.map { |point| point[:delta].to_f.abs }.max.to_f %>
      <% max_abs = 1.0 if max_abs <= 0 %>
      <% y_top = if max_abs < 100 then max_abs.ceil else ((max_abs / 50.0).ceil * 50) end %>
      <% y_bottom = -y_top %>
      <% mid_y = pad_top + (plot_height / 2.0) %>

      <% delta_points = @workout_chart_points.each_with_index.map do |point, index|
        x = pad_left + (step_x * index)
        y = mid_y - ((point[:delta].to_f / y_top) * (plot_height / 2.0))
        format("%.2f,%.2f", x, y)
      end.join(" ") %>

      <div class="progression-chart-legend">
        <span class="progression-chart-legend-item"><span class="progression-chart-key progression-chart-key-delta"></span>Delta (actual - planned)</span>
      </div>

      <div class="progression-chart-wrap" role="img" aria-label="Delta difficulty trend">
        <svg viewBox="0 0 <%= chart_width %> <%= chart_height %>" class="progression-chart-svg" preserveAspectRatio="none" aria-hidden="true">
          <line x1="<%= pad_left %>" y1="<%= pad_top + plot_height %>" x2="<%= chart_width - pad_right %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
          <line x1="<%= pad_left %>" y1="<%= pad_top %>" x2="<%= pad_left %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
          <line x1="<%= pad_left %>" y1="<%= mid_y %>" x2="<%= chart_width - pad_right %>" y2="<%= mid_y %>" class="progression-chart-axis progression-chart-axis-mid" />
          <polyline points="<%= delta_points %>" class="progression-chart-line progression-chart-line-delta" />
          <text x="<%= pad_left - 6 %>" y="<%= pad_top + 4 %>" text-anchor="end" class="progression-chart-label"><%= number_with_precision(y_top, precision: 0) %></text>
          <text x="<%= pad_left - 6 %>" y="<%= mid_y + 4 %>" text-anchor="end" class="progression-chart-label">0</text>
          <text x="<%= pad_left - 6 %>" y="<%= pad_top + plot_height + 4 %>" text-anchor="end" class="progression-chart-label"><%= number_with_precision(y_bottom, precision: 0) %></text>
          <text x="<%= pad_left %>" y="<%= chart_height - 8 %>" text-anchor="start" class="progression-chart-label"><%= first_label %></text>
          <% if @workout_chart_points.size > 1 %>
            <text x="<%= chart_width - pad_right %>" y="<%= chart_height - 8 %>" text-anchor="end" class="progression-chart-label"><%= last_label %></text>
          <% end %>
        </svg>
      </div>
    <% else %>
      <% max_value = @workout_chart_points.flat_map { |point| [point[:planned].to_f, point[:actual].to_f] }.max.to_f %>
      <% max_value = 1.0 if max_value <= 0 %>
      <% y_top = if max_value < 100 then max_value.ceil else ((max_value / 50.0).ceil * 50) end %>

      <% planned_points = @workout_chart_points.each_with_index.map do |point, index|
        x = pad_left + (step_x * index)
        y = pad_top + plot_height - ((point[:planned].to_f / y_top) * plot_height)
        format("%.2f,%.2f", x, y)
      end.join(" ") %>

      <% actual_points = @workout_chart_points.each_with_index.map do |point, index|
        x = pad_left + (step_x * index)
        y = pad_top + plot_height - ((point[:actual].to_f / y_top) * plot_height)
        format("%.2f,%.2f", x, y)
      end.join(" ") %>

      <div class="progression-chart-legend">
        <span class="progression-chart-legend-item"><span class="progression-chart-key progression-chart-key-planned"></span>Planned</span>
        <span class="progression-chart-legend-item"><span class="progression-chart-key progression-chart-key-actual"></span>Actual</span>
      </div>

      <div class="progression-chart-wrap" role="img" aria-label="Planned and actual difficulty trend">
        <svg viewBox="0 0 <%= chart_width %> <%= chart_height %>" class="progression-chart-svg" preserveAspectRatio="none" aria-hidden="true">
          <line x1="<%= pad_left %>" y1="<%= pad_top + plot_height %>" x2="<%= chart_width - pad_right %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
          <line x1="<%= pad_left %>" y1="<%= pad_top %>" x2="<%= pad_left %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
          <polyline points="<%= planned_points %>" class="progression-chart-line progression-chart-line-planned" />
          <polyline points="<%= actual_points %>" class="progression-chart-line progression-chart-line-actual" />
          <text x="<%= pad_left - 6 %>" y="<%= pad_top + 4 %>" text-anchor="end" class="progression-chart-label"><%= number_with_precision(y_top, precision: 0) %></text>
          <text x="<%= pad_left - 6 %>" y="<%= pad_top + plot_height + 4 %>" text-anchor="end" class="progression-chart-label">0</text>
          <text x="<%= pad_left %>" y="<%= chart_height - 8 %>" text-anchor="start" class="progression-chart-label"><%= first_label %></text>
          <% if @workout_chart_points.size > 1 %>
            <text x="<%= chart_width - pad_right %>" y="<%= chart_height - 8 %>" text-anchor="end" class="progression-chart-label"><%= last_label %></text>
          <% end %>
        </svg>
      </div>
    <% end %>
  <% end %>

  <% if @progress_workouts.any? %>
    <div class="progression-table-wrap progression-table-desktop">
      <table class="progression-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Workout</th>
            <th>Type</th>
            <th>Planned</th>
            <th>Actual</th>
            <th>Delta</th>
          </tr>
        </thead>
        <tbody>
          <% @progress_workouts.first(24).each do |workout| %>
            <% delta = workout.actual_total_difficulty.to_d - workout.planned_total_difficulty.to_d %>
            <tr>
              <td><%= workout.workout_on.to_fs(:short) %></td>
              <td><%= link_to workout.title, workout_path(workout) %></td>
              <td><%= workout.workout_type_label %></td>
              <td><%= number_with_precision(workout.planned_total_difficulty, precision: 1) %></td>
              <td><%= number_with_precision(workout.actual_total_difficulty, precision: 1) %></td>
              <td class="progression-delta <%= delta >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>"><%= number_with_precision(delta, precision: 1) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="progression-mobile-list">
      <% @progress_workouts.first(24).each do |workout| %>
        <% planned = workout.planned_total_difficulty.to_d %>
        <% actual = workout.actual_total_difficulty.to_d %>
        <% delta = actual - planned %>
        <% row_attainment = if planned.positive?
          (actual / planned * 100)
        elsif actual.positive?
          BigDecimal("100")
        else
          BigDecimal("100")
        end %>
        <% row_fill = [[row_attainment.to_f, 0.0].max, 100.0].min %>
        <% row_overflow = planned.positive? ? [row_attainment.to_f - 100.0, 0.0].max : 0.0 %>
        <% row_overflow_capped = [row_overflow, 100.0].min %>
        <article class="progression-mobile-row">
          <div class="progression-mobile-head">
            <%= link_to workout.title, workout_path(workout), class: "progression-mobile-title" %>
            <span class="progression-mobile-date"><%= workout.workout_on.to_fs(:short) %></span>
          </div>
          <p class="progression-mobile-meta"><%= workout.workout_type_label %></p>
          <div class="progression-mobile-metrics">
            <div>
              <p class="progression-mobile-label">Planned</p>
              <p class="progression-mobile-value"><%= number_with_precision(planned, precision: 1) %></p>
            </div>
            <div>
              <p class="progression-mobile-label">Actual</p>
              <p class="progression-mobile-value"><%= number_with_precision(actual, precision: 1) %></p>
            </div>
            <div>
              <p class="progression-mobile-label">Delta</p>
              <p class="progression-mobile-value progression-delta <%= delta >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>"><%= number_with_precision(delta, precision: 1) %></p>
            </div>
          </div>
          <div class="progression-mini-attainment" aria-hidden="true">
            <span class="progression-attainment-fill <%= row_attainment >= 100 ? "progression-attainment-fill-over" : "progression-attainment-fill-under" %>" style="width: <%= row_fill %>%"></span>
            <% if row_overflow_capped.positive? %>
              <span class="progression-attainment-overflow" style="width: <%= row_overflow_capped %>%"></span>
            <% end %>
            <span class="progression-attainment-target" aria-hidden="true"></span>
          </div>
          <p class="progression-mobile-meta">Attainment <%= number_with_precision(row_attainment, precision: 0) %>%</p>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="supporting-text">No matching logged workouts yet. Complete a workout to start seeing progression.</p>
  <% end %>
</section>
<% end %>
<% end %>

<% if @tab == "exercises" %>
<section class="card panel-card">
  <div class="section-heading">
    <div>
      <p class="panel-label">Exercises</p>
      <h2>Exercise-level progression</h2>
    </div>
  </div>

  <% if @exercise_stats.any? %>
    <div class="progression-table-wrap progression-table-desktop">
      <table class="progression-table">
        <thead>
          <tr>
            <th>Exercise</th>
            <th>Sessions</th>
            <th>Trend</th>
            <th>Planned</th>
            <th>Actual</th>
            <th>Delta</th>
          </tr>
        </thead>
        <tbody>
          <% @exercise_stats.each do |entry| %>
            <tr>
              <td><%= link_to entry[:exercise].name, progressions_path(tab: "exercises", workout_type: @selected_workout_type, exercise_id: entry[:exercise].id) %></td>
              <td><%= entry[:sessions] %></td>
              <td>
                <% trend_class = case entry[:trend_direction]
                when :up then "trend-pill-up"
                when :down then "trend-pill-down"
                else "trend-pill-neutral"
                end %>
                <% trend_label = case entry[:trend_direction]
                when :up then "Up"
                when :down then "Down"
                else "Flat"
                end %>
                <% trend_symbol = case entry[:trend_direction]
                when :up then "▲"
                when :down then "▼"
                else "•"
                end %>
                <span class="trend-pill <%= trend_class %>">
                  <span aria-hidden="true"><%= trend_symbol %></span>
                  <%= trend_label %>
                </span>
              </td>
              <td><%= number_with_precision(entry[:planned_total], precision: 1) %></td>
              <td><%= number_with_precision(entry[:actual_total], precision: 1) %></td>
              <td class="progression-delta <%= entry[:delta_total] >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>"><%= number_with_precision(entry[:delta_total], precision: 1) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="progression-mobile-list">
      <% @exercise_stats.each do |entry| %>
        <article class="progression-mobile-row">
          <div class="progression-mobile-head">
            <%= link_to entry[:exercise].name, progressions_path(tab: "exercises", workout_type: @selected_workout_type, exercise_id: entry[:exercise].id), class: "progression-mobile-title" %>
            <span class="progression-mobile-date"><%= pluralize(entry[:sessions], "session") %></span>
          </div>
          <p class="progression-mobile-meta">
            <% trend_class = case entry[:trend_direction]
            when :up then "trend-pill-up"
            when :down then "trend-pill-down"
            else "trend-pill-neutral"
            end %>
            <% trend_label = case entry[:trend_direction]
            when :up then "Up"
            when :down then "Down"
            else "Flat"
            end %>
            <% trend_symbol = case entry[:trend_direction]
            when :up then "▲"
            when :down then "▼"
            else "•"
            end %>
            <span class="trend-pill <%= trend_class %>">
              <span aria-hidden="true"><%= trend_symbol %></span>
              <%= trend_label %>
            </span>
            <span class="progression-trend-change"><%= number_with_precision(entry[:trend_delta], precision: 1) %> vs last</span>
          </p>
          <div class="progression-mobile-metrics">
            <div>
              <p class="progression-mobile-label">Planned</p>
              <p class="progression-mobile-value"><%= number_with_precision(entry[:planned_total], precision: 1) %></p>
            </div>
            <div>
              <p class="progression-mobile-label">Actual</p>
              <p class="progression-mobile-value"><%= number_with_precision(entry[:actual_total], precision: 1) %></p>
            </div>
            <div>
              <p class="progression-mobile-label">Delta</p>
              <p class="progression-mobile-value progression-delta <%= entry[:delta_total] >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>"><%= number_with_precision(entry[:delta_total], precision: 1) %></p>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="supporting-text">No exercise progression available for this filter yet.</p>
  <% end %>

  <% if @selected_exercise.present? && @exercise_progress_rows.any? %>
    <div class="progression-exercise-focus">
      <p class="panel-label"><%= @selected_exercise.name %></p>
      <div class="progression-table-wrap progression-table-desktop">
        <table class="progression-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Workout</th>
              <th>Planned</th>
              <th>Actual</th>
              <th>Delta</th>
              <th>Actual sets</th>
            </tr>
          </thead>
          <tbody>
            <% @exercise_progress_rows.each do |row| %>
              <tr>
                <td><%= row[:workout].workout_on.to_fs(:short) %></td>
                <td><%= link_to row[:workout].title, workout_path(row[:workout]) %></td>
                <td><%= number_with_precision(row[:planned_total], precision: 1) %></td>
                <td><%= number_with_precision(row[:actual_total], precision: 1) %></td>
                <td class="progression-delta <%= row[:delta_total] >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>"><%= number_with_precision(row[:delta_total], precision: 1) %></td>
                <td><%= row[:actual_summary] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="progression-mobile-list">
        <% @exercise_progress_rows.each do |row| %>
          <article class="progression-mobile-row">
            <div class="progression-mobile-head">
              <%= link_to row[:workout].title, workout_path(row[:workout]), class: "progression-mobile-title" %>
              <span class="progression-mobile-date"><%= row[:workout].workout_on.to_fs(:short) %></span>
            </div>
            <div class="progression-mobile-metrics">
              <div>
                <p class="progression-mobile-label">Planned</p>
                <p class="progression-mobile-value"><%= number_with_precision(row[:planned_total], precision: 1) %></p>
              </div>
              <div>
                <p class="progression-mobile-label">Actual</p>
                <p class="progression-mobile-value"><%= number_with_precision(row[:actual_total], precision: 1) %></p>
              </div>
              <div>
                <p class="progression-mobile-label">Delta</p>
                <p class="progression-mobile-value progression-delta <%= row[:delta_total] >= 0 ? "progression-delta-positive" : "progression-delta-negative" %>"><%= number_with_precision(row[:delta_total], precision: 1) %></p>
              </div>
            </div>
            <p class="progression-mobile-meta"><strong>Actual sets:</strong> <%= row[:actual_summary] %></p>
          </article>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
<% end %>
  <% end %>
