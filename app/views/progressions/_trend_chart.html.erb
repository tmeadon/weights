<% return if points.blank? %>

<% chart_width = 640 %>
<% chart_height = 230 %>
<% pad_left = 34 %>
<% pad_right = 10 %>
<% pad_top = 16 %>
<% pad_bottom = 34 %>
<% plot_width = chart_width - pad_left - pad_right %>
<% plot_height = chart_height - pad_top - pad_bottom %>
<% step_x = points.size > 1 ? (plot_width.to_f / (points.size - 1)) : 0 %>
<% first_label = points.first[:label] %>
<% last_label = points.last[:label] %>

<% if mode == "relative" %>
  <% relative_values = points.filter_map { |point| point[:relative] } %>
  <% max_abs = relative_values.map { |value| value.to_f.abs }.max.to_f %>
  <% max_abs = 1.0 if max_abs <= 0 %>
  <% y_top = max_abs < 20 ? max_abs.ceil : ((max_abs / 10.0).ceil * 10) %>
  <% y_bottom = -y_top %>
  <% mid_y = pad_top + (plot_height / 2.0) %>
  <% relative_points = points.each_with_index.filter_map do |point, index|
    next if point[:relative].nil?

    x = pad_left + (step_x * index)
    y = mid_y - ((point[:relative].to_f / y_top) * (plot_height / 2.0))
    format("%.2f,%.2f", x, y)
  end.join(" ") %>

  <div class="progression-chart-legend">
    <span class="progression-chart-legend-item"><span class="progression-chart-key progression-chart-key-delta"></span>Relative change (%)</span>
  </div>

  <div class="progression-chart-wrap" role="img" aria-label="<%= aria_label || "Relative difficulty trend" %>">
    <svg viewBox="0 0 <%= chart_width %> <%= chart_height %>" class="progression-chart-svg" preserveAspectRatio="none" aria-hidden="true">
      <line x1="<%= pad_left %>" y1="<%= pad_top + plot_height %>" x2="<%= chart_width - pad_right %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
      <line x1="<%= pad_left %>" y1="<%= pad_top %>" x2="<%= pad_left %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
      <line x1="<%= pad_left %>" y1="<%= mid_y %>" x2="<%= chart_width - pad_right %>" y2="<%= mid_y %>" class="progression-chart-axis progression-chart-axis-mid" />
      <polyline points="<%= relative_points %>" class="progression-chart-line progression-chart-line-delta" />
      <text x="<%= pad_left - 6 %>" y="<%= pad_top + 4 %>" text-anchor="end" class="progression-chart-label"><%= number_with_precision(y_top, precision: 0) %></text>
      <text x="<%= pad_left - 6 %>" y="<%= mid_y + 4 %>" text-anchor="end" class="progression-chart-label">0</text>
      <text x="<%= pad_left - 6 %>" y="<%= pad_top + plot_height + 4 %>" text-anchor="end" class="progression-chart-label"><%= number_with_precision(y_bottom, precision: 0) %></text>
      <text x="<%= pad_left %>" y="<%= chart_height - 8 %>" text-anchor="start" class="progression-chart-label"><%= first_label %></text>
      <% if points.size > 1 %>
        <text x="<%= chart_width - pad_right %>" y="<%= chart_height - 8 %>" text-anchor="end" class="progression-chart-label"><%= last_label %></text>
      <% end %>
    </svg>
  </div>
<% else %>
  <% max_value = points.map { |point| point[:absolute].to_f }.max.to_f %>
  <% max_value = 1.0 if max_value <= 0 %>
  <% y_top = max_value < 100 ? max_value.ceil : ((max_value / 50.0).ceil * 50) %>
  <% absolute_points = points.each_with_index.map do |point, index|
    x = pad_left + (step_x * index)
    y = pad_top + plot_height - ((point[:absolute].to_f / y_top) * plot_height)
    format("%.2f,%.2f", x, y)
  end.join(" ") %>

  <div class="progression-chart-legend">
    <span class="progression-chart-legend-item"><span class="progression-chart-key progression-chart-key-actual"></span>Absolute score</span>
  </div>

  <div class="progression-chart-wrap" role="img" aria-label="<%= aria_label || "Absolute difficulty trend" %>">
    <svg viewBox="0 0 <%= chart_width %> <%= chart_height %>" class="progression-chart-svg" preserveAspectRatio="none" aria-hidden="true">
      <line x1="<%= pad_left %>" y1="<%= pad_top + plot_height %>" x2="<%= chart_width - pad_right %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
      <line x1="<%= pad_left %>" y1="<%= pad_top %>" x2="<%= pad_left %>" y2="<%= pad_top + plot_height %>" class="progression-chart-axis" />
      <polyline points="<%= absolute_points %>" class="progression-chart-line progression-chart-line-actual" />
      <text x="<%= pad_left - 6 %>" y="<%= pad_top + 4 %>" text-anchor="end" class="progression-chart-label"><%= number_with_precision(y_top, precision: 0) %></text>
      <text x="<%= pad_left - 6 %>" y="<%= pad_top + plot_height + 4 %>" text-anchor="end" class="progression-chart-label">0</text>
      <text x="<%= pad_left %>" y="<%= chart_height - 8 %>" text-anchor="start" class="progression-chart-label"><%= first_label %></text>
      <% if points.size > 1 %>
        <text x="<%= chart_width - pad_right %>" y="<%= chart_height - 8 %>" text-anchor="end" class="progression-chart-label"><%= last_label %></text>
      <% end %>
    </svg>
  </div>
<% end %>
